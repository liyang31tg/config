function proxy_on() {
    local port=7890
    if [ $# -eq 1 ]; then
        port=$1
    fi
    export all_proxy=socks5://0.0.0.0:$port
}

function proxy_http_on() {
    local port=7890
    if [ $# -eq 1 ]; then
        port=$1
    fi
    export http_proxy=http://127.0.0.1:$port
    export https_proxy=http://127.0.0.1:$port
}

function proxy_all_on() {
    local port=7890
    if [ $# -eq 1 ]; then
        port=$1
    fi
    export http_proxy=http://127.0.0.1:$port
    export https_proxy=http://127.0.0.1:$port
    export all_proxy=socks5://127.0.0.1:$port
}

function proxy_off() {
    unset http_proxy
    unset https_proxy
    unset all_proxy
}

